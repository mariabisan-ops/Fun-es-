#include <stdio.h>

int multiplicacao (int, int);
int potencia (int, int);


int main(){
    int x,y;
    printf ("digite o valor da base: ");
    scanf ("%d", &x);
    printf ("digite o valor da potência: ");
    scanf ("%d", &y);

    printf ("potência: %d", potencia(x,y));
}

int multiplicacao (int n1, int n2){
    int cont = 0;
    for (int i = 0; i<n2; i++){
        cont = cont + n1;
    }
    return cont;
}

int potencia (int x, int y){
    int resultado = 1;
    for (int i =0; i<y; i++){
        resultado = multiplicacao (resultado, x);
    }
    return resultado;
}
