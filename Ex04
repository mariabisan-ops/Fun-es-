#include <stdio.h>

int inverso (int[], int);

int main(){
    int v[100];
    int n;
    printf ("digite um numero: ");
    scanf ("%d", &n);

    inverso (v,n);
}

int inverso (int v[], int n){
    int cont = 0;
    while (n>0){
        v[cont]=n%10;
        cont++;
        n = n/10;
    }
    for (int i=0; i<cont; i++){
        printf ("%d", v[i]);
    }
}
