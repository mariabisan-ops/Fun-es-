#include <stdio.h>

int ehprimo (int);

int main (){
    int n;
    printf ("digite o número: ");
    scanf ("%d", &n);

    if (ehprimo(n)){
        printf ("é primo");
    }
    else {
        printf ("não é primo");
    }
}

int ehprimo (int n){
    if (n==1){
        return 0;
    }
    for (int i=2; i<n; i++){
        if (n%i==0){
            return 0;
        }
    }

    return 1;
}
