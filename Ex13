#include <stdio.h>

int mdc (int, int);

int main (){
    int x,y;
    do{
    printf ("digite o primeiro número: ");
    scanf ("%d", &x);
    printf ("digite o segundo valor: ");
    scanf ("%d", &y);

    printf ("mdc = %d", mdc(x,y));
    } while (x!=0 && y!=0);
}

int mdc (int a, int b){
    int resto = 0;
    while(b!=0){
        resto = a%b;
        a=b;
        b=resto;
    }
    return a;
}
