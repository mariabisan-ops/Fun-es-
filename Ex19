#include <stdio.h>

int binario (int v[], int);

int main(){
    int v[100];
    int n;
    printf ("digite o valor a ser convertido: ");
    scanf ("%d", &n);

    binario (v,n);
}

int binario (int v[], int n){
    int cont = 0;
    while (n>0){
        v[cont]=n%2;
        cont++;
        n = n/2;
    }
    for (int i=cont-1; i>=0; i--){
        printf ("%d", v[i]);
    }
}
