#include <stdio.h>

void fibonnacci (int );

int main (){
  int n;
  printf (“digite o número de termos:  “);
  scanf (“%d”, &n);
  printf (“sequência : “);
  fibonnacci (n);
}

void fibonnacci (int n){
  int a=0, b=1, c;
  for (int i=1; i<=n; i++){
    if (i==1){
      printf (“%d”, a);
    }
    else {
      if (i==2){
        printf (“%d”, b);
      }
      else {
        c = a + b;
        printf (“%d”, c);
        a=b;
        b=c;
      }
    }
  }
}

