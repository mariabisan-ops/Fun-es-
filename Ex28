#include <stdio.h>

int fibonacci (int [], int);

int main (){
    int v[100];
    int n;
    printf ("digite o tamanho da sequência fibonacci que deseja: ");
    scanf ("%d", &n);

    fibonacci (v,n);
}
int fibonacci (int v[], int n){
    for (int i=0; i<n; i++){
        v[0]=0;
        v[1]=1;
        v[i]=v[i-1]+v[i-2];
    }
    for (int i=0; i<n; i++){
        printf ("%d, ", v[i]);
    }
}
