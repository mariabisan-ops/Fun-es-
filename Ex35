#include <stdio.h>
#include <string.h>

int tamanho (char[]);
int compara (char[], char[]);
void concatena (char[], char[]);

int main(){
    char p[100], p2[50];
    printf ("digite uma palavra: ");
    fgets (p, sizeof(p), stdin);
    p[strlen(p)-1]='\0';

    printf ("digite a segunda palavra: ");
    fgets (p2, sizeof(p2), stdin);
    p2[strlen(p2)-1]='\0';

    printf ("tamanho: %d\n", tamanho(p));

    if (compara(p, p2)){
        printf ("As palavras são iguais");
    }

    printf ("concatena: ");
    concatena (p, p2);

}

int tamanho (char s[]){
    int cont=0;
    while (s[cont]!='\0'){
        cont++;
    }
    return cont;
}

int compara (char s1[], char s2[]){
    int cont=0;
    for (int i=0; i<tamanho(s1); i++){
        if (s1[i]!=s2[i] && s1[i]!='\0'){
            return 0;
        }
        cont++;
    }
    if (cont==tamanho(s1)){
        return 1;
    }
}

void concatena(char s1[], char s2[]){
  int i= tamanho (s1);
  for (int j = 0; j<=tamanho(s2); j++) {
    s1[i] = s2[j];
    i ++;
  }
  s1[i]= '\0';
  printf ("%c ", s1);
}

